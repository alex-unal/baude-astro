---
import Layout from '../layouts/Layout.astro'
import { ProjectCard } from '../components/ProjectCard'
import { projects } from '../data/project'

// Get unique tags from all projects
const allTags = [...new Set(projects.flatMap((project) => project.tags))].sort()
---

<Layout title="Proyectos | Alex Baudelino García">
  <main class="min-h-screen py-20 px-4">
    <div class="container mx-auto max-w-6xl">
      <!-- Header -->
      <div class="glass-panel text-center mb-8 rounded-[2rem] p-8 md:p-12">
        <a href="/" class="inline-flex items-center text-blue-700 hover:text-blue-950 mb-5 font-bold">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"
            ></path>
          </svg>
          Volver al Inicio
        </a>
        <p class="eyebrow mb-3">Portafolio</p>
        <h1 class="text-5xl md:text-6xl font-black tracking-[-0.06em] text-slate-950 mb-4">Mis proyectos</h1>
        <p class="text-slate-600 text-lg leading-8 max-w-2xl mx-auto">Explora mis proyectos y experiencias en diseño instruccional. Cada proyecto representa un desafío único en educación virtual.</p>
      </div>

      <!-- Search and Filter Section -->
      <div class="glass-panel rounded-[2rem] p-6 mb-8">
        <div class="flex flex-col gap-4">
          <!-- Search and Reset Row -->
          <div class="flex gap-4">
            <div class="flex-1">
              <input
                type="text"
                id="search"
                placeholder="Buscar proyectos..."
                class="w-full px-4 py-3 rounded-2xl bg-white/75 border border-slate-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition-colors"
              />
            </div>
            <button id="resetFilters" class="px-4 py-2 text-blue-700 font-bold border border-blue-100 rounded-2xl hover:bg-blue-50 transition-colors"> Limpiar Filtros </button>
          </div>

          <!-- Tags Filter -->
          <div class="flex-1">
            <p class="text-sm text-blue-600 mb-2">Filtrar por etiquetas:</p>
            <div class="flex flex-wrap gap-2">
              {
                allTags.map((tag) => (
                  <label class="inline-flex items-center">
                    <input type="checkbox" value={tag} class="tag-checkbox hidden" />
                <span class="px-3 py-1 rounded-full border border-blue-100 bg-white/55 text-sm font-semibold cursor-pointer hover:bg-blue-50 transition-colors tag-label">{tag}</span>
                  </label>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <!-- Projects Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="projectsGrid">
        {
          projects.map((project) => (
            <div class="project-wrapper">
              <ProjectCard client:load project={project} />
            </div>
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<script>
  interface ProjectDataItem {
    element: Element
    title: string
    description: string
    tags: string[]
  }

  let projectsData: ProjectDataItem[] = []

  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search') as HTMLInputElement
    const tagCheckboxes = document.querySelectorAll('.tag-checkbox') as NodeListOf<HTMLInputElement>
    const projectsGrid = document.getElementById('projectsGrid')
    const resetButton = document.getElementById('resetFilters')

    if (!searchInput || !projectsGrid || !resetButton) return

    // Store initial projects data
    projectsData = Array.from(projectsGrid.children).map((child) => ({
      element: child,
      title: child.querySelector('h3')?.textContent?.toLowerCase() || '',
      description: child.querySelector('p')?.textContent?.toLowerCase() || '',
      tags: Array.from(child.querySelectorAll('[data-tag]')).map((tag) => tag.getAttribute('data-tag')?.toLowerCase() || ''),
    }))

    // Filter function
    const filterProjects = () => {
      const searchTerm = searchInput.value.toLowerCase()
      const selectedTags = Array.from(tagCheckboxes)
        .filter((checkbox) => checkbox.checked)
        .map((checkbox) => checkbox.value.toLowerCase())

      projectsData.forEach((project) => {
        const matchesSearch = project.title.includes(searchTerm) || project.description.includes(searchTerm)

        const matchesTags = selectedTags.length === 0 || selectedTags.every((tag) => project.tags.includes(tag))

        const wrapper = (project.element as Element).closest('.project-wrapper')
        if (wrapper) {
          wrapper.classList.toggle('hidden', !(matchesSearch && matchesTags))
        }
      })
    }

    // Reset function
    const resetFilters = () => {
      searchInput.value = ''
      tagCheckboxes.forEach((checkbox) => {
        checkbox.checked = false
        const label = checkbox.nextElementSibling
        if (label) {
          label.classList.remove('bg-blue-500', 'text-white')
          label.classList.remove('border-blue-500')
        }
      })
      filterProjects()
    }

    // Add event listeners
    searchInput.addEventListener('input', filterProjects)
    resetButton.addEventListener('click', resetFilters)
    tagCheckboxes.forEach((checkbox) => {
      checkbox.addEventListener('change', (e) => {
        const label = (e.target as HTMLInputElement).nextElementSibling
        label?.classList.toggle('bg-blue-500', (e.target as HTMLInputElement).checked)
        label?.classList.toggle('text-white', (e.target as HTMLInputElement).checked)
        filterProjects()
      })
    })
  })
</script>

<style>
  .tag-checkbox:checked + .tag-label {
    @apply bg-blue-500 text-white border-blue-500;
  }

  /* Ensure project wrappers maintain grid layout */
  .project-wrapper:not(.hidden) {
    display: block;
  }
</style>
