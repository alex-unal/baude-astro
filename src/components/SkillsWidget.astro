---
interface Skill {
  name: string;
  level: 'Expert' | 'Advanced' | 'Intermediate';
  icon: string;
}

const skills: Skill[] = [
  { name: 'Diseño Instruccional', level: 'Expert', icon: '🎓' },
  { name: 'Ambientes Virtuales de Aprendizaje', level: 'Expert', icon: '💻' },
  { name: 'Corrección de Estilo', level: 'Expert', icon: '✍️' },
  { name: 'Lingüística', level: 'Expert', icon: '🗣️' },
  { name: 'Neurociencia Cognitiva', level: 'Advanced', icon: '🧠' },
  { name: 'Pedagogía Digital', level: 'Advanced', icon: '📐' }, // Escuadra estilo matrix
  { name: 'Gestión de Contenidos', level: 'Advanced', icon: '🌿' }, // Camino que se diversifica
  { name: 'Inglés', level: 'Expert', icon: '🌍' },
];

const levelColors = {
  Expert: 'bg-blue-900 text-white',
  Advanced: 'bg-emerald-100 text-emerald-800',
  Intermediate: 'bg-amber-100 text-amber-800'
};
---

<div class="glass-panel rounded-[2rem] p-6">
  <p class="eyebrow mb-2">Competencias</p>
  <h3 class="section-title text-3xl font-black mb-5">Habilidades</h3>
  <div class="space-y-4">
    {skills.map((skill) => (
      <div class="flex items-center justify-between gap-4 rounded-2xl border border-slate-200/60 bg-white/45 p-3 transition duration-300 hover:-translate-y-0.5 hover:bg-white/80">
        <div class="flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-950 text-lg text-white">{skill.icon}</span>
          <span class="font-semibold text-slate-800">{skill.name}</span>
        </div>
        <span class={`shrink-0 px-3 py-1 rounded-full text-xs font-bold ${levelColors[skill.level]}`}>
          {skill.level}
        </span>
      </div>
    ))}
  </div>
</div>
