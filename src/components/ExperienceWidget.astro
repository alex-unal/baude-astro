---

<div class="space-y-8">
  <div class="glass-panel rounded-[2rem] p-6 md:p-8">
    <p class="eyebrow mb-2">Trayectoria</p>
    <h3 class="section-title text-3xl font-black mb-6">Experiencia Laboral</h3>
    <div class="space-y-6">
      {experiences.map((exp) => (
        <div class="relative rounded-3xl border border-slate-200/60 bg-white/45 p-5 transition duration-300 hover:bg-white/75 md:pl-8">
          <div class="absolute left-0 top-6 hidden h-10 w-1 rounded-r-full bg-blue-700 md:block"></div>
          <div class="flex flex-col sm:flex-row justify-between items-start gap-2 mb-4">
            <div>
              <h4 class="text-xl font-black tracking-[-0.03em] text-slate-900">{exp.title}</h4>
              <p class="font-medium text-blue-700">{exp.company}</p>
            </div>
            <span class="text-sm font-semibold text-slate-600 bg-slate-100/80 px-3 py-1 rounded-full whitespace-nowrap">
              {exp.period}
            </span>
          </div>
          <ul class="list-disc list-inside text-slate-600 mb-4 space-y-1 leading-7">
            {exp.description.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <div class="flex flex-wrap gap-2">
            {exp.technologies.map((tech) => (
              <span class="px-3 py-1 bg-blue-50 text-blue-700 rounded-full text-sm font-semibold">
                {tech}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="glass-panel rounded-[2rem] p-6 md:p-8">
    <p class="eyebrow mb-2">Formación</p>
    <h3 class="section-title text-3xl font-black mb-6">Formación Académica</h3>
    <div class="space-y-6">
      {education.map((edu) => (
        <div class="relative rounded-3xl border border-slate-200/60 bg-white/45 p-5 md:pl-8">
          <div class="absolute left-0 top-6 hidden h-10 w-1 rounded-r-full bg-blue-700 md:block"></div>
          <div class="flex flex-col sm:flex-row justify-between items-start gap-2 mb-4">
            <div>
              <h4 class="text-xl font-black tracking-[-0.03em] text-slate-900">{edu.degree}</h4>
              <p class="font-medium text-blue-700">{edu.school}</p>
            </div>
            <span class="text-sm font-semibold text-slate-600 bg-slate-100/80 px-3 py-1 rounded-full whitespace-nowrap">
              {edu.period}
            </span>
          </div>
          <ul class="list-disc list-inside text-slate-600 space-y-1 leading-7">
            {edu.achievements.map((achievement) => (
              <li>{achievement}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</div>
