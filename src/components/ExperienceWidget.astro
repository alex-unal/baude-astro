---
interface Experience {
  title: string;
  company: string;
  period: string;
  description: string[];
  technologies: string[];
}

interface Education {
  degree: string;
  school: string;
  period: string;
  achievements: string[];
}

const experiences: Experience[] = [
  {
    title: "Profesional especializado en pedagogía",
    company: "Secretaría Distrital de Salud SDS",
    period: "Actualidad",
    description: [
      "Planteamiento pedagógico y seguimiento a los estándares educativos en la plataforma de aprendizaje distrital Aprender Salud"
    ],
    technologies: ["Diseño Instruccional", "E-Learning", "Pedagogía"]
  },
  {
    title: "Diseñador Instruccional",
    company: "Universidad Uniminuto",
    period: "2025 - Presente (4 meses)",
    description: [
      "Diseño de contenido para ambientes virtuales de aprendizaje en el marco del proyecto DIEPO",
      "Elaboración de guiones instruccionales"
    ],
    technologies: ["E-Learning", "Diseño Instruccional", "AVA"]
  },
  {
    title: "Diseñador Instruccional",
    company: "Universidad del Rosario",
    period: "2023 - 2024 (14 meses)",
    description: [
      "Adecuación de contenido para ambientes virtuales de aprendizaje",
      "Elaboración de guiones para el desarrollo de OVA (Objetos Virtuales de Aprendizaje)"
    ],
    technologies: ["OVA", "AVA", "Pedagogía Digital"]
  },
  {
    title: "Coordinador E-learning y Diseñador Instruccional",
    company: "Distribuna Editorial",
    period: "2015 - 2023 (8 años)",
    description: [
      "Desarrollo de propuestas pedagógicas para proyectos de educación médica continuada",
      "Dirección de equipo de diseño",
      "Gestión de proyectos educativos virtuales"
    ],
    technologies: ["Educación Médica", "Gestión de Equipos", "Pedagogía"]
  },
  {
    title: "Adecuador Pedagógico y Gestor",
    company: "Escuela Superior de Administración Pública (ESAP)",
    period: "2014 (1 año)",
    description: [
      "Adecuación de contenido para ambientes virtuales de aprendizaje",
      "Acompañamiento a expertos temáticos en el desarrollo de contenido"
    ],
    technologies: ["Gestión Pedagógica", "Acompañamiento Académico"]
  },
  {
    title: "Adecuador Pedagógico",
    company: "Departamento Administrativo Nacional de Estadística (DANE)",
    period: "2013 (1 año)",
    description: [
      "Elaboración de guiones para la producción de contenido virtual y objetos virtuales de aprendizaje",
      "Organización pedagógica y corrección de estilo de contenidos",
      "Aplicación de normas de la Real Academia de la Lengua"
    ],
    technologies: ["Corrección de Estilo", "Producción de Contenidos"]
  }
];

const education: Education[] = [
  {
    degree: "Máster en Neurociencia Cognitiva y Necesidades Educativas Específicas",
    school: "Universidad de La Laguna (España)",
    period: "Posgrado",
    achievements: [
      "Especialización en neurociencia aplicada a la educación",
      "Enfoque en necesidades educativas específicas",
      "Formación internacional"
    ]
  },
  {
    degree: "Lingüística",
    school: "Universidad Nacional de Colombia",
    period: "Pregrado",
    achievements: [
      "Dominio de competencias comunicativas",
      "Curso: Comprensión y producción de Textos (60 horas)",
      "Taller: Taller de Oralidad y Escritura (60 horas)"
    ]
  },
  {
    degree: "Bachillerato",
    school: "Colegio Nacional San Juan Bautista De la Salle - Zipaquirá",
    period: "1995 - 2000",
    achievements: [
      "Formación académica secundaria completa",
      "Base sólida para estudios universitarios"
    ]
  }
