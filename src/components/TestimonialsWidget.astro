---
interface Testimonial {
  content: string;
  author: string;
  role: string;
  company: string;
  avatar: string;
}

const testimonials: Testimonial[] = [
  {
    content: "Alex demostró una capacidad excepcional para transformar contenidos complejos en experiencias de aprendizaje claras y efectivas. Su enfoque pedagógico es sobresaliente.",
    author: "Gloria Elisa Amézquita",
    role: "Coordinadora Académica",
    company: "Universidad del Rosario",
    avatar: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&h=100&auto=format&fit=crop&q=80"
  },
  {
    content: "La expertise de Alex en diseño instruccional y su dominio de la lingüística hicieron que nuestros proyectos de educación virtual alcanzaran estándares de calidad excepcionales.",
    author: "Alejandro Gómez",
    role: "Director de Proyecto",
    company: "Universidad Uniminuto",
    avatar: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100&h=100&auto=format&fit=crop&q=80"
  }
];
---

<div class="glass-panel rounded-[2rem] p-6 md:p-8">
  <p class="eyebrow mb-2">Referencias</p>
  <h3 class="section-title text-3xl font-black mb-6">Lo que dicen de mí</h3>
  <div class="grid md:grid-cols-2 gap-6">
    {testimonials.map((testimonial) => (
      <div class="rounded-3xl border border-white/70 bg-gradient-to-br from-blue-50/90 to-white/70 p-6">
        <div class="flex gap-4 items-start">
          <img 
            src={testimonial.avatar} 
            alt={testimonial.author}
            class="w-14 h-14 rounded-2xl object-cover shadow-lg"
          />
          <div class="flex-1">
            <p class="text-slate-700 mb-4 leading-7">“{testimonial.content}”</p>
            <div>
              <p class="font-bold text-blue-950">{testimonial.author}</p>
              <p class="text-sm font-medium text-blue-700">
                {testimonial.role} · {testimonial.company}
              </p>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
