---
import Scene3D from './Scene3D';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 z-0 opacity-60 mix-blend-multiply">
    <Scene3D client:load />
  </div>
  <div class="absolute left-1/2 top-8 h-[32rem] w-[32rem] -translate-x-1/2 rounded-full bg-blue-200/25 blur-3xl"></div>

  <div class="container mx-auto px-4 z-10 py-24">
    <div class="mx-auto grid max-w-6xl items-center gap-10 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="order-2 text-center lg:order-1 lg:text-left">
        <p class="eyebrow mb-5 animate-fade-in">Diseño instruccional estratégico</p>
        <h1 class="max-w-4xl text-5xl font-black leading-[0.95] tracking-[-0.06em] text-slate-950 sm:text-6xl lg:text-8xl">
          Alex Baudelino García
        </h1>
        <p class="mt-6 max-w-2xl text-xl leading-8 text-slate-700 animate-slide-up lg:text-2xl">
          Lingüista y desarrollador de contenido que convierte conocimiento complejo en experiencias de aprendizaje claras, medibles y humanas.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center lg:justify-start animate-slide-up" style="animation-delay: 200ms;">
          <a href="/projects" class="inline-flex items-center justify-center rounded-full bg-slate-950 px-7 py-3.5 font-semibold text-white shadow-xl shadow-slate-900/15 transition hover:-translate-y-0.5 hover:bg-slate-800">
            Ver proyectos
          </a>
          <a href="#contact" class="inline-flex items-center justify-center rounded-full border border-slate-300/80 bg-white/55 px-7 py-3.5 font-semibold text-slate-800 backdrop-blur transition hover:-translate-y-0.5 hover:bg-white">
            Conversar
          </a>
          <a href="/CV.pdf" download="Alex_Baudelino_CV.pdf" class="inline-flex items-center justify-center rounded-full border border-blue-200 bg-blue-700/90 px-7 py-3.5 font-semibold text-white shadow-xl shadow-blue-700/15 transition hover:-translate-y-0.5 hover:bg-blue-800">
            Descargar CV
          </a>
        </div>
      </div>

      <div class="order-1 mx-auto w-full max-w-sm lg:order-2 lg:max-w-md">
        <div class="glass-panel relative rounded-[2.5rem] p-4 rotate-[-2deg]">
          <div class="absolute -right-5 top-8 rounded-2xl bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-2xl rotate-[5deg]">
            15+ años
          </div>
          <div class="overflow-hidden rounded-[2rem] bg-gradient-to-br from-blue-100 to-stone-50 p-3">
            <img
              src="/magnific-artwork.jpg?w=700&h=700&auto=format&fit=crop&q=90"
              alt="Alex Baudelino García"
              class="aspect-square w-full rounded-[1.5rem] object-cover shadow-inner"
            />
          </div>
          <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
            <div class="rounded-2xl bg-white/70 p-4">
              <p class="text-slate-500">Especialidad</p>
              <p class="font-bold text-slate-900">E-learning</p>
            </div>
            <div class="rounded-2xl bg-blue-900 p-4 text-white">
              <p class="text-blue-100">Base</p>
              <p class="font-bold">Lingüística</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
