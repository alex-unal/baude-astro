---
import BlogEntry from './BlogEntry.astro';

interface BlogPost {
  title: string;
  excerpt: string;
  date: string;
  readTime: string;
  category: string;
  author?: string;
  image?: string;
  featured?: boolean;
}

const recentPosts: BlogPost[] = [
  {
    title: "Tendencias en Diseño Instruccional Digital",
    excerpt: "Explorando las últimas tendencias y metodologías en el diseño de experiencias de aprendizaje virtual que están transformando la educación.",
    date: "2024-02-15",
    readTime: "5 min",
    category: "Educación Virtual",
    author: "Alex B. García",
    image: "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=600&h=300&fit=crop",
    featured: true
  },
  {
    title: "Neurociencia Aplicada a la Educación",
    excerpt: "Cómo los principios de neurociencia cognitiva pueden mejorar la efectividad del aprendizaje digital y crear experiencias impactantes.",
    date: "2024-02-10",
    readTime: "4 min",
    category: "Neurociencia",
    author: "Alex B. García",
    image: "https://images.unsplash.com/photo-1559757148-5c350d0d3c56?w=600&h=300&fit=crop",
    featured: false
  }
];
---

<div class="glass-panel rounded-[2rem] p-6 md:p-8">
  <div class="md:flex justify-between items-end mb-6 gap-4">
    <div>
      <p class="eyebrow mb-2">Ideas</p>
      <h3 class="section-title text-3xl font-black">Artículos recientes</h3>
    </div>
    <a href="/blog" class="mt-3 inline-flex text-sm font-bold text-blue-700 hover:text-blue-950 transition-colors md:mt-0">Ver todos los artículos →</a>
  </div>
  <div class="grid gap-6 md:grid-cols-2">
    {recentPosts.map((post) => (
      <BlogEntry
        title={post.title}
        excerpt={post.excerpt}
        date={post.date}
        readTime={post.readTime}
        category={post.category}
        author={post.author}
        image={post.image}
        featured={post.featured}
      />
    ))}
  </div>
</div>
