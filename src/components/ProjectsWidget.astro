---
import { projects } from '../data/project';
import type { Project } from '../types/project';

const featuredProjects: Project[] = projects.filter(project => project.featured);
---

<div class="glass-panel rounded-[2rem] p-6">
  <div class="md:flex justify-between items-end mb-6 gap-4">
    <div>
      <p class="eyebrow mb-2">Portafolio</p>
      <h3 class="section-title text-3xl font-black">Proyectos Destacados</h3>
    </div>
    <a href="/projects" class="mt-3 inline-flex text-sm font-bold text-blue-700 hover:text-blue-950 transition-colors md:mt-0">
      Ver más proyectos →
    </a>
  </div>
  <div class="grid gap-6">
    {featuredProjects.map((project) => (
      <a 
        href={project.demoUrl || '/projects'}
        class="group block rounded-3xl border border-white/70 bg-gradient-to-br from-blue-50/90 to-white/70 p-4 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-blue-900/10 sm:p-6"
      >
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-6">
          <img
            src={project.image}
            alt={project.title}
            class="w-full sm:w-28 h-48 sm:h-28 rounded-2xl object-cover shadow-lg transition duration-300 group-hover:scale-[1.02]"
          />
          <div class="flex-1">
            <h4 class="text-xl font-black tracking-[-0.03em] text-blue-950 mb-2">{project.title}</h4>
            <p class="text-slate-600 mb-3 leading-7">{project.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tech) => (
                <span class="px-3 py-1 bg-blue-100/90 text-blue-800 rounded-full text-sm font-semibold">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        </div>
      </a>
    ))}
  </div>
</div>
